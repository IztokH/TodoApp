<Window x:Class="TodoApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Todo App New XAML" Height="450" Width="400">

    <Grid Margin="10">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Search -->
            <RowDefinition Height="Auto"/>
            <!-- Input -->
            <RowDefinition Height="Auto"/>
            <!-- Filters -->
            <RowDefinition Height="*"/>
            <!-- List -->
        </Grid.RowDefinitions>

        <!-- 🔍 Search -->
        <StackPanel Grid.Row="0" Margin="0,0,0,10">
            <TextBlock Text="Search:"
               FontWeight="Bold"
               Margin="0,0,0,5"/>

            <TextBox Height="30"
             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />
        </StackPanel>

        <!-- 📝 Add Task -->
        <StackPanel Grid.Row="1" Margin="0,0,0,10">

            <TextBlock Text="Add Task:"
               FontWeight="Bold"
               Margin="0,0,0,5"/>

            <StackPanel Orientation="Horizontal">
                <TextBox Width="250"
                 Height="30"
                 Margin="0,0,10,0"
                 Text="{Binding TaskInput, UpdateSourceTrigger=PropertyChanged}" />

                <Button Content="Add"
                Width="80"
                Height="30"
                Click="Add_Click"/>
            </StackPanel>

        </StackPanel>

        <!-- 🔽 Filters -->
        <StackPanel Grid.Row="2" Margin="0,0,0,10">

            <TextBlock Text="🔽 Filter Tasks"
               FontWeight="Bold"
               Margin="0,0,0,5"/>

            <StackPanel Orientation="Horizontal">

                <!-- ALL -->
                <Button Content="All" Click="FilterAll_Click" Margin="5">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="LightGray"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedFilter}" Value="All">
                                    <Setter Property="Background" Value="LightBlue"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <!-- DONE -->
                <Button Content="Done" Click="FilterDone_Click" Margin="5">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="LightGray"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedFilter}" Value="Done">
                                    <Setter Property="Background" Value="LightBlue"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <!-- PENDING -->
                <Button Content="Pending" Click="FilterPending_Click" Margin="5">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="LightGray"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedFilter}" Value="Pending">
                                    <Setter Property="Background" Value="LightBlue"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

            </StackPanel>

        </StackPanel>

        <!-- 📋 Task List -->
        <ListBox Grid.Row="3"
             ItemsSource="{Binding TasksView}">

            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal">

                        <!-- Task Text -->
                        <TextBlock Text="{Binding Title}" Margin="5">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="TextDecorations" Value="{x:Null}"/>
                                    <Setter Property="Opacity" Value="1"/>

                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsDone}" Value="True">
                                            <Setter Property="TextDecorations" Value="Strikethrough"/>
                                            <Setter Property="Opacity" Value="0.5"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <!-- Toggle Done -->
                        <Button Margin="5"
                            Click="Done_Click">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Content" Value="✔"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsDone}" Value="True">
                                            <Setter Property="Content" Value="↺"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <!-- Delete -->
                        <Button Content="X"
                            Click="Delete_Click"
                            Margin="5"/>

                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>

        </ListBox>

    </Grid>
</Window>